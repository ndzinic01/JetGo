# JetGo local development configuration
# Copy this file to ".env" and replace placeholder values with your local settings.

JETGO_CONNECTION_STRING=Server=<SQL_SERVER_INSTANCE>;Database=<BROJ_INDEKSA>;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True
JETGO_JWT_ISSUER=JetGo.API
JETGO_JWT_AUDIENCE=JetGo.Client
JETGO_JWT_KEY=<POSTAVI_DUGACAK_JWT_SECRET>
JETGO_JWT_EXPIRY_MINUTES=60
JETGO_SQL_SA_PASSWORD=<POSTAVI_SQL_SA_PASSWORD>
JETGO_RABBITMQ_DEFAULT_USER=<RABBITMQ_DEFAULT_USER>
JETGO_RABBITMQ_DEFAULT_PASS=<RABBITMQ_DEFAULT_PASS>
JETGO_RABBITMQ_HOST=<RABBITMQ_HOST>
JETGO_RABBITMQ_PORT=5672
JETGO_RABBITMQ_USERNAME=<RABBITMQ_USERNAME>
JETGO_RABBITMQ_PASSWORD=<RABBITMQ_PASSWORD>
JETGO_RABBITMQ_VIRTUAL_HOST=<RABBITMQ_VIRTUAL_HOST>
JETGO_RABBITMQ_NOTIFICATIONS_QUEUE=<RABBITMQ_NOTIFICATIONS_QUEUE>
JETGO_PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
JETGO_PAYPAL_CLIENT_ID=<PAYPAL_SANDBOX_CLIENT_ID>
JETGO_PAYPAL_CLIENT_SECRET=<PAYPAL_SANDBOX_CLIENT_SECRET>
JETGO_PAYPAL_CURRENCY_CODE=EUR
JETGO_PAYPAL_BAM_TO_CURRENCY_RATE=1.95583
