# JetGo local development configuration
# Copy this file to ".env" and replace placeholder values with your local settings.

JETGO_CONNECTION_STRING=Server=<SQL_SERVER_INSTANCE>;Database=<BROJ_INDEKSA>;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True
JETGO_JWT_ISSUER=JetGo.API
JETGO_JWT_AUDIENCE=JetGo.Client
JETGO_JWT_KEY=<POSTAVI_DUGACAK_JWT_SECRET>
JETGO_JWT_EXPIRY_MINUTES=60
